# Secrets — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem
secrets/
credentials.json
SECRETS.md

# Claude local settings (may contain tokens)
.claude/settings.local.json
.claude/launch.json

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Node / Dev
node_modules/
dist/
build/
.cache/
*.log

# Python
__pycache__/
*.pyc
.venv/
venv/

# Large video files (stay local, too big for GitHub)
*.mp4
!website/assets/video/*.mp4

# Netlify local
.netlify/
website/.netlify/

# Backups (created during deploys/migrations)
website-backup-*/

# Raw assets (not for deployment — may contain unblurred faces)
raw-assets/

# Dev files
website/palette-preview.html
website/content-text.txt

# Generated / Output drafts that shouldn't be shared publicly
# (output/ contains work-in-progress — keep local by default)
# Uncomment next line if you ever want output/ private:
# output/

# Claude worktrees (local session checkouts)
.claude/worktrees/
