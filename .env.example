# סיפורימה — Environment Variables Template
# ============================================
# This file is a TEMPLATE. Safe to commit.
#
# To use:
# 1. Copy this file to ".env" (remove the .example)
# 2. Fill in your real values
# 3. NEVER commit .env — it's in .gitignore
#
# Each agent that needs a key reads from .env automatically.

# ---- Google Gemini / Nano Banana ----
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-goes-here

# ---- Future keys (add as we grow) ----
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# SENDGRID_API_KEY=
